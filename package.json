{
  "name": "@stronger-ecommerce/smartkart-api",
  "version": "0.1.3",
  "description": "TypeScript client for the SmartKart (RDT Connectors) API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      },
      "require": {
        "types": "./dist/schemas.d.cts",
        "default": "./dist/schemas.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "openapi.yaml",
    "AGENTS.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "verify-package": "npm run build && publint && attw --pack --profile node16",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && publint && attw --pack --profile node16",
    "watch": "tsup --watch"
  },
  "keywords": [
    "smartkart",
    "rdt",
    "pos",
    "api",
    "gadget"
  ],
  "license": "MIT",
  "author": "Jay <jay@strongerecommerce.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stronger-eCommerce/smartkart-api.git"
  },
  "bugs": {
    "url": "https://github.com/Stronger-eCommerce/smartkart-api/issues"
  },
  "homepage": "https://github.com/Stronger-eCommerce/smartkart-api#readme",
  "bin": {
    "smartkart-mcp": "./dist/mcp-server.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^25.6.0",
    "publint": "^0.3.19",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
